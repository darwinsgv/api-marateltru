const getClienteWispPorCedula = async (req, res) => {
  const { cedula } = req.params;

  try {
    let url = 'https://api.wisphub.net/api/clientes/?limit=100';

    while (url) {
      const response = await axios.get(url, {
        headers: {
          Authorization: `Api-Key ${process.env.WISP_API_KEY}`
        }
      });

      const data = response.data;

      const cliente = data.results.find(c => c.cedula == cedula);

      if (cliente) {
        return res.json(cliente);
      }

      url = data.next;
    }

    return res.status(404).json({ message: 'Cliente no encontrado' });

  } catch (error) {
    console.error(error.response?.data || error.message);

    res.status(500).json({
      error: 'Error al buscar cliente'
    });
  }
};

const getFacturaWispPorCedula = async (req, res) => {
  const { cedula } = req.params;

  try {
    let url = 'https://api.wisphub.net/api/facturas/?limit=100';
    let facturasCliente = [];

    while (url) {
      const response = await axios.get(url, {
        headers: {
          Authorization: `Api-Key ${process.env.WISP_API_KEY}`
        }
      });

      const data = response.data;

      const filtradas = data.results.filter(
        f => f.cliente && f.cliente.cedula == cedula
      );

      facturasCliente = facturasCliente.concat(filtradas);

      url = data.next;
    }

    if (facturasCliente.length === 0) {
      return res.status(404).json({ message: 'Factura no encontrada' });
    }

    res.json(facturasCliente);

  } catch (error) {
    console.error(error.response?.data || error.message);

    res.status(500).json({
      error: 'Error al buscar factura'
    });
  }
};


const getFacturaWispPorNombreCompleto = async (req, res) => {
  const { nombre } = req.params;

  try {
    let url = 'https://api.wisphub.net/api/facturas/?limit=100';
    let resultados = [];

    while (url) {
      const response = await axios.get(url, {
        headers: {
          Authorization: `Api-Key ${process.env.WISP_API_KEY}`
        }
      });

      const data = response.data;

      const filtradas = data.results.filter(f => {
        // Validación segura
        if (!f.cliente || !f.cliente.nombre) return false;

        return f.cliente.nombre.toLowerCase().includes(nombre.toLowerCase());
      });

      resultados = resultados.concat(filtradas);

      url = data.next;
    }

    if (resultados.length === 0) {
      return res.status(404).json({ message: 'No se encontraron facturas' });
    }

    res.json(resultados);

  } catch (error) {
    console.error(error.response?.data || error.message);

    res.status(500).json({
      error: 'Error al buscar facturas por nombre'
    });
  }
};

