const axios = require('axios');

const getClientesWisp = async (req, res) => {
  try {
    const response = await axios.get(
      //'https://sandbox-api.wisphub.net/api/clientes',//pruebas
      //'https://api.wisphub.net/api/modelo-antena',
      'https://api.wisphub.net/api/clientes/?cedula=V30047959',
      
      {
        headers: {
          Authorization: `Api-Key ${process.env.WISP_API_KEY}`
        }
      }
    );

    res.json(response.data);

  } catch (error) {
    console.error('ERROR WISP:', error.response?.data || error.message);

    res.status(error.response?.status || 500).json({
      error: error.response?.data || 'Error al consumir WispHub'
    });
  }
};


const getClienteWispPorCedula = async (req, res) => {
  const { cedula } = req.params;

  try {
    const response = await axios.get(
      'https://api.wisphub.net/api/clientes/',
      {
        headers: {
          Authorization: `Api-Key ${process.env.WISP_API_KEY}`
        }
      }
    );

    const clientes = response.data.results;

    const cliente = clientes.find(c => c.cedula === cedula);

    if (!cliente) {
      return res.status(404).json({ message: 'Cliente no encontrado' });
    }

    res.json(cliente);

  } catch (error) {
    console.error(error.response?.data || error.message);

    res.status(500).json({
      error: 'Error al buscar cliente'
    });
  }
};


const getFacturaWispPorCedula = async (req, res) => {
  const { cedula } = req.params;

  try {
    const response = await axios.get(
      'https://api.wisphub.net/api/facturas/',
      {
        headers: {
          Authorization: `Api-Key ${process.env.WISP_API_KEY}`
        }
      }
    );

    const facturas = response.data.results;

    // ⚠️ aquí depende de cómo venga la data
    const facturasCliente = facturas.filter(f => f.cliente.cedula === cedula);

    if (facturasCliente.length === 0) {
      return res.status(404).json({ message: 'Factura no encontrada' });
    }

    res.json(facturasCliente);

  } catch (error) {
    console.error(error.response?.data || error.message);

    res.status(500).json({
      error: 'Error al buscar factura'
    });
  }
};
module.exports = {
  getClientesWisp,
  getClienteWispPorCedula,
  getFacturaWispPorCedula
};